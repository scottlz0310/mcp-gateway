# ============================================================
# mcp-gateway: copilot-review-routing example
# Copy this file to .env and fill in your values.
# ============================================================

# ---- GitHub Personal Access Token (for github-mcp-server) ----
# Fine-grained token (recommended):
#   Permissions: Contents/Issues/Pull requests (Read & Write), Metadata (Read)
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- GitHub OAuth App credentials ----
# Create at: https://github.com/settings/applications/new
#   Homepage URL:              http://localhost:8080
#   Authorization callback URL: http://localhost:8080/callback
#
# mcp-gateway uses GITHUB_MCP_CLIENT_ID / GITHUB_MCP_CLIENT_SECRET.
# copilot-review-mcp uses GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET.
# You may use the same OAuth App for both.
GITHUB_MCP_CLIENT_ID=Ov23xxxxxxxxxxxxxxxx
GITHUB_MCP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

GITHUB_CLIENT_ID=Ov23xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- mcp-gateway ----
MCP_GATEWAY_BASE_URL=http://localhost:8080
# MCP_GATEWAY_PORT=8080

# ---- copilot-review-mcp ----
# COPILOT_REVIEW_MCP_PORT=8083
# COPILOT_REVIEW_BASE_URL=http://localhost:8083

# ---- Shared settings ----
LOG_LEVEL=info
# SESSION_TTL_MIN=10
# TOKEN_CACHE_TTL_MIN=30
# GITHUB_MCP_OAUTH_SCOPES=repo,user

# ---- Image overrides (optional) ----
# GITHUB_MCP_IMAGE=ghcr.io/github/github-mcp-server:main
# COPILOT_REVIEW_MCP_IMAGE=ghcr.io/scottlz0310/copilot-review-mcp:main
